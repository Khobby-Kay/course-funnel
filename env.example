# =============================================================================
# Course Funnel — Environment Variables
# Copy this file to `.env.local` and fill in your values when ready.
# =============================================================================

# App URL (required for payment callbacks in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# WhatsApp (sales support)
# Format: country code + number, no + or spaces. Example Ghana: 233241234567
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=233000000000
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hi! I have a question about the Digital Marketing course.

# -----------------------------------------------------------------------------
# Course access (LMS gating) — required in production
# Signs the httpOnly cookie that unlocks /dashboard after verified payment.
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
ACCESS_SECRET=

# -----------------------------------------------------------------------------
# Built-in LMS at /dashboard (payment-gated). Optional external redirect override.
# Leave NEXT_PUBLIC_LMS_URL blank to use the built-in course dashboard.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_LMS_URL=

# Optional: auto-redirect delay on success page (seconds). 0 = manual only.
NEXT_PUBLIC_SUCCESS_REDIRECT_SECONDS=5

# -----------------------------------------------------------------------------
# Media assets — drop files in /public/assets/ or use full URLs
# Leave blank to show placeholders until you add real assets.
# -----------------------------------------------------------------------------
# Leave blank until files exist in /public/assets/ (shows placeholders)
NEXT_PUBLIC_INSTRUCTOR_PHOTO=
NEXT_PUBLIC_COURSE_VIDEO_URL=
NEXT_PUBLIC_COURSE_VIDEO_POSTER=
NEXT_PUBLIC_SCREENSHOT_1=
NEXT_PUBLIC_SCREENSHOT_2=
NEXT_PUBLIC_SCREENSHOT_3=

# -----------------------------------------------------------------------------
# Paystack — https://dashboard.paystack.com/#/settings/developer
# Secret key stays server-side only. Public key is safe for the browser.
# Supports: Mobile Money, Visa, Mastercard, bank (Ghana)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxx

# -----------------------------------------------------------------------------
# Flutterwave — https://dashboard.flutterwave.com/settings/apis
# Supports: Mobile Money, cards, bank (multi-country)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxx

# -----------------------------------------------------------------------------
# Moolre — https://app.moolre.com (Ghana MoMo: MTN, Telecel, AT)
# Mobile Money collections via hosted payment link.
# Sandbox base URL used automatically when MOOLRE_SANDBOX=true
# -----------------------------------------------------------------------------
MOOLRE_API_USER=your_moolre_username
MOOLRE_PUBLIC_KEY=your_moolre_public_key
MOOLRE_ACCOUNT_NUMBER=your_wallet_account_number
MOOLRE_SANDBOX=true

# Webhook secrets (optional but recommended in production)
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_WEBHOOK_SECRET=

# Demo mode: set to "true" to simulate payments without API keys (local dev)
PAYMENTS_DEMO_MODE=true

# -----------------------------------------------------------------------------
# Admin panel — /admin (manage courses: upload, publish, take down)
# Default dev password: admin123 — CHANGE in production
# -----------------------------------------------------------------------------
ADMIN_PASSWORD=admin123
ADMIN_SECRET=
# Optional: only this email may use Supabase Auth for /admin (create user in Supabase → Authentication)
ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# Supabase — private LMS video hosting (Storage bucket: course-videos)
# Run supabase/storage.sql in your Supabase SQL editor after creating a project.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Email (Resend) — confirmation emails + admin messaging
# https://resend.com — verify your sending domain for production
# EMAIL_FROM must use a verified domain, e.g. Course Funnel <hello@yourdomain.com>
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
